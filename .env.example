```bash
# .env.example

# Application Environment
APP_ENV=local
APP_DEBUG=true
APP_KEY=

# Database
DB_CONNECTION=mongodb
DB_HOST=127.0.0.1
DB_PORT=27017
DB_DATABASE=laravel_ai_crm
DB_USERNAME=
DB_PASSWORD=

# MongoDB
MONGO_DB_CONNECTION=mongodb
MONGO_DB_HOST=127.0.0.1
MONGO_DB_PORT=27017
MONGO_DB_DATABASE=laravel_ai_crm
MONGO_DB_USERNAME=
MONGO_DB_PASSWORD=

# Horizon
HORIZON_SQS_QUEUE_DRIVER=redis
HORIZON_SQS_REDIS_HOST=127.0.0.1
HORIZON_SQS_REDIS_PORT=6379

# Sanctum
SANCTUM_STATEFUL=true

# Reverb
REVERB_DRIVER=redis
REVERB_REDIS_HOST=127.0.0.1
REVERB_REDIS_PORT=6379

# Inertia
INERTIA_APP_ID=
INERTIA_APP_KEY=
INERTIA_APP_SECRET=

# Pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# OpenAI
OPENAI_API_KEY=
OPENAI_API_SECRET=

# Cashier
CASHIER_MODE=live
CASHIER_TEST_MODE=false
CASHIER_STRIPE_KEY=
CASHIER_STRIPE_SECRET=

# Permission
PERMISSION_MODEL=App\Models\User

# Excel
EXCEL_EXPORT_PATH=storage/excel

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Queue
QUEUE_CONNECTION=redis
QUEUE_DRIVER=redis
QUEUE_REDIS_HOST=127.0.0.1
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=0

# Mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# AI
AI_MODEL_ID=
AI_API_KEY=
AI_API_SECRET=
```